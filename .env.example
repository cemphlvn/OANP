# ===== LLM Configuration =====
# Supports any OpenAI-compatible API. Choose ONE provider:

# Option A: OpenAI
OPENAI_API_KEY=your_openai_api_key_here
# OANP_DEFAULT_MODEL=gpt-4o

# Option B: Anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OANP_DEFAULT_MODEL=claude-sonnet-4-6

# Option C: Any OpenAI-compatible endpoint (Ollama, Together, etc.)
# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=http://localhost:11434/v1
# OANP_DEFAULT_MODEL=llama3

# ===== Graphiti / Neo4j Configuration (Optional) =====
# Required only for knowledge graph memory features
# Free Neo4j Aura instance: https://neo4j.com/cloud/aura-free/
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# ===== Server Configuration =====
OANP_HOST=0.0.0.0
OANP_PORT=8123
